# ─────────────────────────────────────────────────────────────────────────────
# NeoWatch environment variables — TEMPLATE
#
# HOW TO USE:
#   1. Copy this file to ".env"      ->  cp .env.example .env
#   2. Paste your real keys below the "=" signs in .env (no quotes, no spaces).
#   3. NEVER commit ".env" — it is git-ignored. Only this template is committed.
#
# pydantic-settings (see src/neowatch/config.py) loads these at runtime.
# ─────────────────────────────────────────────────────────────────────────────

# --- REQUIRED SECRETS ---------------------------------------------------------

# Anthropic API key — powers every agent (Claude Haiku + Sonnet).
# Get one at https://console.anthropic.com  (Settings -> API Keys).
# TIP: also set a monthly spend limit (Settings -> Limits) as a cost backstop.
# Format: starts with "sk-ant-".
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# NASA API key — powers NeoWs (asteroids), APOD (images), DONKI (space weather).
# Free, instant: https://api.nasa.gov  (1,000 requests/hour).
NASA_API_KEY=your-nasa-api-key-here


# --- OPTIONAL -----------------------------------------------------------------

# SERP API key — NOT required (arXiv needs no key). Leave blank unless you add
# a search feature that uses it later.
SERP_API_KEY=


# --- TUNABLES (safe defaults; override only if you know why) -------------------

# Claude model routing (cheap model for tool calls, capable model for reasoning).
HAIKU_MODEL=claude-haiku-4-5
SONNET_MODEL=claude-sonnet-4-6

# Cost / context guardrails.
TOKEN_BUDGET_PER_SESSION=200000   # hard cap on tokens (≈ cost) per user session
MAX_TOKENS_PER_AGENT=4096         # per-agent output budget

# Local paths / logging.
CHROMA_PERSIST_DIR=.chroma        # where the RAG vector store lives on disk
LOG_LEVEL=INFO                    # DEBUG | INFO | WARNING | ERROR

# Watch loop (recurring, stateful outer loop — see docs/WATCH_LOOP_PLAN.md).
WATCH_STATE_DIR=.watch_state          # per-vertical snapshots + alerts.jsonl audit (git-ignored)
WATCH_INTERVAL_SECONDS=10800          # in-process re-check cadence (3h; Kp ~3-hourly, EONET ~daily)
WATCH_KP_ALERT_GSCALE=G1              # geomagnetic storm alert threshold (G1..G5)
WATCH_EVENTS_ACTIVE_THRESHOLD=50      # active-event count that counts as a surge
